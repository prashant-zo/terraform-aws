variable "aws_region" {
  description = "AWS region"
  type        = string
  default     = "ap-south-1"
}

variable "project" {
  description = "Project Name"
  type        = string
  default     = "prashantapp"
}

variable "environment" {
  description = "Environment type"
  type        = string
  default     = "env"
}

